{
  "name": "stocks-signal-executor",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "description": "Automated trading execution bot integrating Zerodha Kite, Active/Closed Trades APIs, and Telegram notifications.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "dev:watch": "nodemon",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "script:fetch-instruments": "ts-node src/scripts/fetchInstruments.ts"
  },
  "dependencies": {
    "axios": "^1.6.8",
    "dayjs": "^1.11.10",
    "dotenv": "^16.4.1",
    "ioredis": "^5.3.2",
    "pg": "^8.11.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/pg": "^8.16.0",
    "ioredis-mock": "^8.10.1",
    "nock": "^13.5.2",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "vitest": "^1.6.0"
  }
}
