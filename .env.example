# Broker (Dhan) credentials (use a secrets manager in production)
DHAN_CLIENT_ID="YOUR_DHAN_CLIENT_ID"
# Optional: initial access token if not provided via Telegram
# DHAN_ACCESS_TOKEN="YOUR_DHAN_ACCESS_TOKEN"

# External APIs
ACTIVE_TRADES_URL="https://api.example.com/active-trades"
CLOSED_TRADES_URL="https://api.example.com/closed-trades"

# Redis & Postgres
REDIS_URL="redis://localhost:6379"
PG_HOST="localhost"
PG_PORT="5432"
PG_DATABASE="stocks_executor"
PG_USER="postgres"
PG_PASSWORD="postgres"

# Telegram Bot
TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"
TELEGRAM_CHAT_ID="YOUR_DEFAULT_CHAT_ID"

# Bot config
POLLING_INTERVAL_MS="15000" # 15 seconds
MAX_TRADE_CAPITAL="25000" # Rs.
TSL_INCREMENT_RS="2" # trailing increment (absolute Rs)
TSL_INITIAL_SL_PCT="3" # initial SL percent below entry
TSL_TRAILING_STEP_PCT="1" # move SL each +1% CMP

# Instruments mapping (not required if upstream provides securityId)
# INSTRUMENTS_JSON_PATH="./data/instruments.json"

# Session refresh (only for Kite legacy, ignore if using Dhan)
SESSION_REFRESH_WINDOW_START="08:45"
SESSION_REFRESH_WINDOW_END="09:00"
